#!/usr/bin/env bash

set -euo pipefail

show_help() {
  cat <<'HELP'
Usage: ./group_records --input PATH --matcher MATCHER [options]

Group CSV rows that may represent the same person.

Required:
  --input PATH                       CSV file to process.
  --matcher MATCHER                  One of: same_email, same_phone, same_email_or_phone.

Options:
  --output-dir DIR, --output_dir DIR
                                     Directory for the full output CSV. Defaults to outputs/.
  --email-column COLUMN, --email_column COLUMN
                                     Email column to use instead of inferred email columns.
  --phone-column COLUMN, --phone_column COLUMN
                                     Phone column to use instead of inferred phone columns.
  --infer-column-names true|false, --infer_column_names true|false
                                     With explicit columns, true also includes inferred columns.
                                     Without explicit columns, inference is on by default.
  -h, --help                         Show this help.

Output:
  Writes the full grouped CSV to the output directory and prints the header plus
  the last 100 data rows to stdout.
HELP
}

has_value_for() {
  local name="$1"
  shift

  while (($#)); do
    case "$1" in
      "$name")
        [[ -n "${2:-}" && "${2:0:1}" != "-" ]] && return 0
        return 1
        ;;
      "$name="*)
        [[ -n "${1#*=}" ]] && return 0
        return 1
        ;;
    esac
    shift
  done

  return 1
}

for arg in "$@"; do
  case "$arg" in
    -h|--help)
      show_help
      exit 0
      ;;
  esac
done

if ! has_value_for "--input" "$@"; then
  echo "Error: --input is required" >&2
  exit 1
fi

if ! has_value_for "--matcher" "$@"; then
  echo "Error: --matcher is required" >&2
  exit 1
fi

if ! command -v ruby >/dev/null 2>&1 || ! ruby -e 'exit(RUBY_VERSION.start_with?("4.") ? 0 : 1)' >/dev/null 2>&1; then
  echo "Error: Ruby 4 is required" >&2
  exit 1
fi

if ! bundle check >/dev/null 2>&1; then
  bundle install
fi

exec ruby -Ilib exe/group_records "$@"
